      "id": "w12-pg",
      "name": "Log to Postgres",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        3300,
        200
      ],
      "parameters": {
        "operation": "insert",
        "schema": {
          "__rl": true,
          "mode": "list",
          "value": "public"
        },
        "table": {
          "__rl": true,
          "mode": "list",
          "value": "ea_workflow_log"
        },
        "dataMode": "defineBelow",
        "valuesToSend": {
          "values": [
            {
              "column": "workflow_id",
              "value": "W-12"
            },
            {
              "column": "workflow_name",
              "value": "W-12: Self-Healing Retry"
            },
            {
              "column": "execution_id",
              "value": "={{ $execution.id }}"
            },
            {
              "column": "status",
              "value": "={{ $('IF Retry 3 Failed').item ? ($('IF Retry 3 Failed').item.json.error ? 'escalated' : 'retried') : 'retried' }}"
            },
            {
              "column": "payload",
              "value": "={{ JSON.stringify({ retryWorkflowId: $('Set Retry Context').item.json.retryWorkflowId, retryWorkflowName: $('Set Retry Context').item.json.retryWorkflowName, errorMsg: $('Set Retry Context').item.json.errorMsg }) }}"
            }
          ]
        },
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "JAcUp4C9hXXmw1ix",
          "name": "EA Postgres"
        }
      }
    },
    {
      "id": "w12-line",
      "name": "LINE Final Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3550,
        200
      ],
      "onError": "continueRegularOutput",
      "parameters": {
        "language": "javaScript",
        "jsCode": "const { execSync } = require('child_process');\ntry {\n  execSync(`osascript -e 'display notification \"Self-healing sequence complete\" with title \"EA-CTO\" subtitle \"W-12: Self-Healing\" sound name \"Default\"'`);\n} catch(e) { /* notification non-fatal */ }\nreturn $input.all();"
      }
    }
