{
  "name": "W-12: Self-Healing Retry",
  "nodes": [
    {
      "id": "w12-err",
      "name": "Error Trigger",
      "type": "n8n-nodes-base.errorTrigger",
      "typeVersion": 1,
      "position": [
        250,
        300
      ],
      "parameters": {}
    },
    {
      "id": "w12-set",
      "name": "Set Retry Context",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        500,
        300
      ],
      "parameters": {
        "mode": "manual",
        "duplicateItem": false,
        "assignments": {
          "assignments": [
            {
              "id": "1",
              "name": "retryWorkflowId",
              "value": "={{ $json.workflow.id }}",
              "type": "string"
            },
            {
              "id": "2",
              "name": "retryWorkflowName",
              "value": "={{ $json.workflow.name }}",
              "type": "string"
            },
            {
              "id": "3",
              "name": "errorMsg",
              "value": "={{ $json.execution.error?.message || 'unknown' }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "w12-wait1",
      "name": "Wait 30s (1)",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [
        750,
        300
      ],
      "parameters": {
        "resume": "timeInterval",
        "amount": 30,
        "unit": "seconds"
      },
      "webhookId": "w12-wait1-webhook"
    },
    {
      "id": "w12-retry1",
      "name": "Retry 1",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1000,
        300
      ],
      "parameters": {
        "method": "POST",
        "url": "=http://localhost:5678/api/v1/workflows/{{ $('Set Retry Context').item.json.retryWorkflowId }}/run",
        "sendBody": true,
        "bodyParameters": {
          "parameters": []
        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          },
          "allowUnauthorizedCerts": false
        },
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth"
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "i0rmMKi7llZ0GnTt",
          "name": "n8n API Key"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "id": "w12-if1",
      "name": "IF Retry 1 Failed",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        1250,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "1",
              "leftValue": "={{ $json.error || ($json.code !== undefined && $json.code >= 400) }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "or"
        }
      }
    },
    {
      "id": "w12-wait2",
      "name": "Wait 30s (2)",
