        "genericAuthType": "httpHeaderAuth"
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "RH1WdQLyd6TaR2dm",
          "name": "EA PIP API Key"
        }
      }
    },
    {
      "id": "w11-lie",
      "name": "w11-lie",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1000,
        300
      ],
      "onError": "continueRegularOutput",
