{
  "name": "W-11 Weekly Report",
  "nodes": [
    {
      "id": "w11-sched",
      "name": "w11-sched",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        250,
        300
      ],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "weeks",
              "triggerAtDay": [
                1
              ],
              "triggerAtHour": 7,
              "triggerAtMinute": 15
            }
          ]
        }
      }
    },
    {
      "id": "w11-wh",
      "name": "w11-wh",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        250,
        500
      ],
      "webhookId": "w11-test-static",
      "onError": "continueRegularOutput",
      "parameters": {
        "httpMethod": "GET",
        "path": "w11-test",
        "responseMode": "lastNode",
        "responseData": "firstEntryJson"
      }
    },
    {
      "id": "w11-fci",
      "name": "w11-fci",
      "type": "n8n-nodes-base.httpRequest",
