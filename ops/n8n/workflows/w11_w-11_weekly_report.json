    },
    {
      "id": "w11-dis",
      "name": "w11-dis",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1250,
        300
      ],
      "onError": "continueRegularOutput",
      "parameters": {
        "method": "GET",
        "url": "http://localhost:8002/documents?limit=10",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        },
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth"
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "NCoCayaGbWY3cbnL",
          "name": "EA DIS Token"
        }
      }
    },
    {
      "id": "w11-code",
      "name": "w11-code",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1500,
        300
      ],
      "parameters": {
        "jsCode": "const weekDate = $now.toISO().slice(0, 10);\n\nconst fciData = $(\"w11-fci\").item.json;\nconst pipData = $(\"w11-pip\").item.json;\nconst lieData = $(\"w11-lie\").item.json;\nconst disData = $(\"w11-dis\").item.json;\n\nconst fciCount = Array.isArray(fciData) ? fciData.length : (fciData.total ?? fciData.count ?? (fciData.anomalies ? fciData.anomalies.length : 'N/A'));\nconst pipCount = Array.isArray(pipData) ? pipData.length : (pipData.total ?? pipData.count ?? (pipData.packages ? pipData.packages.length : 'N/A'));\nconst lieCount = Array.isArray(lieData) ? lieData.length : (lieData.total ?? lieData.count ?? (lieData.obligations ? lieData.obligations.length : 'N/A'));\nconst disCount = Array.isArray(disData) ? disData.length : (disData.total ?? disData.count ?? (disData.documents ? disData.documents.length : 'N/A'));\n\nconst report = '[W-11] Weekly Report ' + weekDate + '\\nFCI Anomalies: ' + fciCount + '\\nPIP Packages: ' + pipCount + '\\nLIE Obligations (7d): ' + lieCount + '\\nDIS Documents: ' + disCount;\n\nreturn [{ json: { message: report.slice(0, 1000) } }];"
      }
    },
    {
      "id": "w11-pg",
      "name": "w11-pg",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        1750,
        300
      ],
      "onError": "continueRegularOutput",
      "parameters": {
        "operation": "executeQuery",
        "query": "=INSERT INTO ea_workflow_log (workflow_id, workflow_name, execution_id, status, payload) VALUES ('W-11', 'W-11 Weekly Report', '={{ $execution.id }}', 'success', '{{ JSON.stringify({message: $json.message}) }}'::jsonb)"
      },
      "credentials": {
        "postgres": {
          "id": "JAcUp4C9hXXmw1ix",
          "name": "EA Postgres"
        }
      }
    },
    {
      "id": "w11-line",
      "name": "w11-line",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2000,
        300
      ],
      "onError": "continueRegularOutput",
      "parameters": {
        "language": "javaScript",
        "jsCode": "const { execSync } = require('child_process');\ntry {\n  execSync(`osascript -e 'display notification \"Weekly management report ready \u2014 see n8n W-11 for full KPIs\" with title \"EA-CTO\" subtitle \"W-11: Weekly Report\" sound name \"Default\"'`);\n} catch(e) { /* notification non-fatal */ }\nreturn $input.all();"
      }
    }
  ],
